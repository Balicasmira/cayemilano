            "liquid": "<!-- ══ DELIVERY INFO — Zalando Style ══ -->\n<style>\n  .zdlv {\n    font-family: 'Jost', 'DM Sans', Arial, sans-serif;\n    margin: 14px 0;\n  }\n\n  .zdlv__row {\n    display: flex;\n    align-items: flex-start;\n    gap: 12px;\n    padding: 10px 0;\n    border-bottom: 1px solid #F0EDE8;\n  }\n\n  .zdlv__row:last-child {\n    border-bottom: none;\n  }\n\n  .zdlv__icon {\n    color: #1A1610;\n    flex-shrink: 0;\n    margin-top: 2px;\n  }\n\n  .zdlv__icon svg {\n    width: 20px;\n    height: 20px;\n    display: block;\n  }\n\n  .zdlv__info {\n    flex: 1;\n  }\n\n  .zdlv__title {\n    font-size: 13px;\n    font-weight: 700;\n    color: #1A1610;\n    display: block;\n    margin-bottom: 2px;\n  }\n\n  .zdlv__meta {\n    display: flex;\n    align-items: center;\n    gap: 10px;\n  }\n\n  .zdlv__date {\n    font-size: 12.5px;\n    font-weight: 500;\n    color: #4B4540;\n  }\n\n  .zdlv__price {\n    font-size: 12.5px;\n    font-weight: 600;\n    color: #16A34A;\n  }\n</style>\n\n<div class=\"zdlv\">\n\n  <!-- Livraison -->\n  <div class=\"zdlv__row\">\n    <div class=\"zdlv__icon\">\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n        <path d=\"M2.231 8.25h2.282a.75.75 0 0 0 0-1.5H2.231a.75.75 0 0 0 0 1.5m2.266 3a.75.75 0 0 0 0-1.5H.753a.75.75 0 0 0 0 1.5zm.017 3.001a.75.75 0 0 0 0-1.5H2.21a.75.75 0 0 0 0 1.5z\"/>\n        <path d=\"m23.81 11.501-3.368-3.738a.75.75 0 0 0-.557-.248h-3.378V4.497a.75.75 0 0 0-.75-.75H3.711a.75.75 0 0 0 0 1.5l11.298-.004.003 10.513-4.953.004c-.519-.897-1.478-1.508-2.588-1.508s-2.07.61-2.588 1.508H3.712a.75.75 0 1 0 0 1.5h.76a2.999 2.999 0 0 0 5.998 0h5.276l.76.003a2.999 2.999 0 0 0 5.997 0h.749a.75.75 0 0 0 .75-.75v-4.51a.75.75 0 0 0-.193-.502m-16.338 7.25a1.5 1.5 0 1 1 0-2.999 1.5 1.5 0 0 1 0 2.999m12.032 0a1.5 1.5 0 1 1 0-2.999 1.5 1.5 0 0 1 0 2.999m2.998-2.988h-.408a2.99 2.99 0 0 0-2.59-1.511 2.99 2.99 0 0 0-2.59 1.511h-.402l-.003-6.748h3.042l2.95 3.278z\"/>\n      </svg>\n    </div>\n    <div class=\"\">\n<p><span class=\"\">Livraison avec num&eacute;ro de suivi <span style=\"color: #339966;\"><b>- Gratuite </span></span></p>\n      <div class=\"zdlv__meta\">\n      \n        \n      </div>\n    </div>\n  </div>\n\n  <!-- Retour -->\n  <div class=\"zdlv__row\">\n    <div class=\"zdlv__icon\">\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n        <path d=\"M17.091 5.511A8.5 8.5 0 1 0 20.5 12.5h-1.502A7 7 0 1 1 16.03 6.56l-2.281 2.281A.75.75 0 0 0 14.28 10h5.97a.75.75 0 0 0 .75-.75V3.28a.75.75 0 0 0-1.28-.53z\"/>\n      </svg>\n    </div>\n    <div class=\"zdlv__info\">\n      <span class=\"zdlv__title\">Retour gratuit sous 30 jours</span>\n      <div class=\"zdlv__meta\">\n        <span class=\"zdlv__date\">Sans question posée</span>\n        <span class=\"zdlv__price\">Gratuit</span>\n      </div>\n    </div>\n  </div>\n\n</div>\n\n<script>\n(function(){\n  var TZ = 'Europe/Paris';\n  var FR_DAYS   = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];\n  var FR_MONTHS = ['Jan','Fév','Mar','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];\n\n  function nowParis(){\n    return new Date(new Date().toLocaleString('en-US', { timeZone: TZ }));\n  }\n\n  function addBizDays(d, n){\n    var r = new Date(d), added = 0;\n    while(added < n){\n      r.setDate(r.getDate() + 1);\n      if(r.getDay() !== 0 && r.getDay() !== 6) added++;\n    }\n    return r;\n  }\n\n  function fmt(d){\n    return FR_DAYS[d.getDay()] + ' ' + d.getDate() + ' ' + FR_MONTHS[d.getMonth()];\n  }\n\n  var now  = nowParis();\n  var base = new Date(now);\n  base.setDate(base.getDate() + 1);\n  while(base.getDay() === 0 || base.getDay() === 6){\n    base.setDate(base.getDate() + 1);\n  }\n\n  var earliest = addBizDays(base, 5);\n  var latest   = addBizDays(base, 7);\n\n  document.getElementById('zdlv-date').textContent =\n    fmt(earliest) + ' – ' + fmt(latest);\n})();\n</script>\n<!-- ════════════════════════════════════════ -->"
