            "liquid": "<div class=\"product-info__liquid\">\n            <div class=\"product-info__liquid\">\n            <div class=\"product-block\">\n                      \n  <style>\n    @font-face {\n      font-family: 'Twentieth Century';\n      src: url('/path-to-your-font/twentieth-century.ttf') format('truetype');\n    }\n\n    .notification {\n      background-color: #ffecec;\n      border-left: 5px solid #ff6b6b;\n      padding: 10px 15px;\n      font-size: 15px;\n      font-family: 'Twentieth Century', sans-serif;\n      color: #333;\n      margin-top: 20px;\n      border-radius: 5px;\n    }\n\n    .notification b {\n      font-weight: bold;\n    }\n  </style>\n\n\n\n          </div>\n          </div>\n\n<hr style=\"border: none; border-top: 1px solid black; margin: 20px 0;\">"
