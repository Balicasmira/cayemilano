          "settings": {
            "liquid": "<div class=\"product-infos__liquid\">\n  <style>\n    .product-infos__liquid {\n      text-align: center;\n    }\n    .kiel-ship-wrap {\n      display: inline-flex;\n      align-items: center;\n      gap: 8px;\n      padding: 6px 10px;\n      font-family: 'Jost', 'DM Sans', Arial, sans-serif;\n      background-color: #ffffff;\n      border-bottom: 1px solid #1A1610; /* <-- Underline added here */\n    }\n    .kiel-ship-icon {\n      color: #1A1610;\n      display: flex;\n      align-items: center;\n      flex-shrink: 0;\n    }\n    .kiel-ship-icon svg {\n      width: 20px;\n      height: 20px;\n    }\n    .kiel-ship-info {\n      display: inline-flex;\n      align-items: center;\n      gap: 6px;\n      font-size: 13px;\n      font-weight: 500;\n      color: #1A1610;\n    }\n    .kiel-ship-free {\n      font-weight: 700;\n      color: #16A34A;\n    }\n  </style>\n\n  <div class=\"kiel-ship-wrap\">\n    <div class=\"kiel-ship-icon\">\n      <svg viewBox=\"0 0 24 24\" fill=\"currentColor\">\n        <path d=\"M2.231 8.25h2.282a.75.75 0 0 0 0-1.5H2.231a.75.75 0 0 0 0 1.5m2.266 3a.75.75 0 0 0 0-1.5H.753a.75.75 0 0 0 0 1.5zm.017 3.001a.75.75 0 0 0 0-1.5H2.21a.75.75 0 0 0 0 1.5z\"></path>\n        <path d=\"m23.81 11.501-3.368-3.738a.75.75 0 0 0-.557-.248h-3.378V4.497a.75.75 0 0 0-.75-.75H3.711a.75.75 0 0 0 0 1.5l11.298-.004.003 10.513-4.953.004c-.519-.897-1.478-1.508-2.588-1.508s-2.07.61-2.588 1.508H3.712a.75.75 0 1 0 0 1.5h.76a2.999 2.999 0 0 0 5.998 0h5.276l.76.003a2.999 2.999 0 0 0 5.997 0h.749a.75.75 0 0 0 .75-.75v-4.51a.75.75 0 0 0-.193-.502\"></path>\n      </svg>\n    </div>\n\n    <div class=\"kiel-ship-info\">\n      <strong>Livraison:</strong>\n      <span id=\"kiel-ship-dates\">Sam 7 Mars – Mar 10 Mars</span>\n      <span class=\"kiel-ship-free\">Gratuite</span>\n    </div>\n  </div>\n\n  <script>\n    (function(){\n      var kielTZ = 'Europe/Paris';\n      var kielDays = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];\n      var kielMonths = ['Jan','Fév','Mars','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];\n\n      function kielNowParis(){\n        return new Date(new Date().toLocaleString('en-US', { timeZone: kielTZ }));\n      }\n\n      function kielAddBizDays(d, n){\n        var r = new Date(d), added = 0;\n        while(added < n){\n          r.setDate(r.getDate() + 1);\n          if(r.getDay() !== 0 && r.getDay() !== 5) added++;\n        }\n        return r;\n      }\n\n      function kielFmt(d){\n        return kielDays[d.getDay()] + ' ' + d.getDate() + ' ' + kielMonths[d.getMonth()];\n      }\n\n      var kielNow = kielNowParis();\n      var kielBase = new Date(kielNow);\n      kielBase.setDate(kielBase.getDate() + 1);\n\n      while(kielBase.getDay() === 0 || kielBase.getDay() === 5){\n        kielBase.setDate(kielBase.getDate() + 1);\n      }\n\n      document.getElementById('kiel-ship-dates').textContent =\n        kielFmt(kielAddBizDays(kielBase, 3)) + ' – ' + kielFmt(kielAddBizDays(kielBase, 5));\n    })();\n  </script>\n</div>"
          }
