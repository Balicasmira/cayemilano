          "settings": {
            "liquid": "<br>\n<style>\n  .dt__wrap,\n  .dt__wrap * {\n    box-sizing: border-box;\n    margin: 0;\n    padding: 0;\n  }\n\n  .dt__wrap {\n    width: 100%;\n    max-width: 420px;\n    padding: 20px 24px;\n    background: #fff;\n    border: 1px solid #EBEBEB;\n    border-radius: 14px;\n    box-shadow: 0 2px 12px rgba(0,0,0,0.06);\n  }\n\n  .dt__label {\n    font-size: 12px;\n    font-weight: 700;\n    letter-spacing: 1.5px;\n    text-transform: uppercase;\n    color: #1A1A1A;\n    margin-bottom: 18px;\n    display: block;\n    text-align: center;\n  }\n\n  .dt__track {\n    display: flex;\n    align-items: flex-start;\n    position: relative;\n  }\n\n  .dt__track::before {\n    content: '';\n    position: absolute;\n    top: 27px;\n    left: calc(16.66% + 4px);\n    right: calc(16.66% + 4px);\n    height: 1px;\n    background: #E8E8E8;\n    z-index: 0;\n  }\n\n  .dt__step {\n    flex: 1;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    gap: 9px;\n    position: relative;\n    z-index: 1;\n  }\n\n  .dt__icon-wrap {\n    width: 54px;\n    height: 54px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    border: 1.5px solid #E0E0E0;\n    background: #fff;\n    box-shadow: 0 2px 6px rgba(0,0,0,0.05);\n    flex-shrink: 0;\n  }\n\n  .dt__icon-wrap svg {\n    width: 20px;\n    height: 20px;\n  }\n\n  /* Commande — grey */\n  .dt__step--grey .dt__icon-wrap {\n    border-color: #C8C8C8;\n    background: #F8F8F8;\n  }\n  .dt__step--grey .dt__step-label { color: #999; }\n\n  /* Expédié — orange */\n  .dt__step--orange .dt__icon-wrap {\n    border-color: #E8761A;\n    background: #FFF6EF;\n  }\n  .dt__step--orange .dt__step-label { color: #E8761A; }\n\n  /* Livraison — green */\n  .dt__step--green .dt__icon-wrap {\n    border-color: #1E5A3C;\n    background: #F0F7F4;\n  }\n  .dt__step--green .dt__step-label { color: #1E5A3C; }\n\n  .dt__info { text-align: center; }\n\n  .dt__step-label {\n    font-size: 10px;\n    font-weight: 700;\n    letter-spacing: 0.5px;\n    text-transform: uppercase;\n    display: block;\n    margin-bottom: 3px;\n  }\n\n  .dt__date {\n    font-size: 12px;\n    font-weight: 700;\n    color: #1A1A1A;\n    display: block;\n    line-height: 1.3;\n  }\n\n  .dt__subdate {\n    font-size: 11px;\n    color: #888;\n    display: block;\n    margin-top: 1px;\n  }\n\n  /* MOBILE */\n  @media (max-width: 420px) {\n    .dt__wrap { padding: 16px 14px; }\n    .dt__icon-wrap { width: 44px; height: 44px; }\n    .dt__icon-wrap svg { width: 17px; height: 17px; }\n    .dt__track::before { top: 21px; }\n    .dt__step-label { font-size: 9px; letter-spacing: 0; }\n    .dt__date { font-size: 11px; }\n    .dt__subdate { font-size: 10px; }\n    .dt__label { font-size: 11px; letter-spacing: 1px; }\n  }\n</style>\n\n<div class=\"dt__wrap\">\n  <span class=\"dt__label\">📦 Estimation de livraison ( 5-7 Jours)</span>\n  <div class=\"dt__track\">\n\n    <!-- STEP 1: Commande — grey -->\n    <div class=\"dt__step dt__step--grey\">\n      <div class=\"dt__icon-wrap\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\">\n          <path d=\"M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z\" stroke=\"#999\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <line x1=\"3\" y1=\"6\" x2=\"21\" y2=\"6\" stroke=\"#999\" stroke-width=\"1.5\" stroke-linecap=\"round\"/>\n          <path d=\"M16 10a4 4 0 01-8 0\" stroke=\"#999\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </div>\n      <div class=\"dt__info\">\n        <span class=\"dt__step-label\">Commande</span>\n        <span class=\"dt__date\" id=\"dt-order-date\">—</span>\n      </div>\n    </div>\n\n    <!-- STEP 2: Expédié — orange -->\n    <div class=\"dt__step dt__step--orange\">\n      <div class=\"dt__icon-wrap\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\">\n          <rect x=\"1\" y=\"3\" width=\"15\" height=\"13\" rx=\"1\" stroke=\"#E8761A\" stroke-width=\"1.5\"/>\n          <path d=\"M16 8h4l3 3v5h-7V8z\" stroke=\"#E8761A\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <circle cx=\"5.5\" cy=\"18.5\" r=\"2.5\" stroke=\"#E8761A\" stroke-width=\"1.5\"/>\n          <circle cx=\"18.5\" cy=\"18.5\" r=\"2.5\" stroke=\"#E8761A\" stroke-width=\"1.5\"/>\n        </svg>\n      </div>\n      <div class=\"dt__info\">\n        <span class=\"dt__step-label\">Expédié</span>\n        <span class=\"dt__date\" id=\"dt-ship-date\">—</span>\n      </div>\n    </div>\n\n    <!-- STEP 3: Livraison — green -->\n    <div class=\"dt__step dt__step--green\">\n      <div class=\"dt__icon-wrap\">\n        <svg viewBox=\"0 0 24 24\" fill=\"none\">\n          <path d=\"M22 11.08V12a10 10 0 11-5.93-9.14\" stroke=\"#1E5A3C\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n          <polyline points=\"22 4 12 14.01 9 11.01\" stroke=\"#1E5A3C\" stroke-width=\"1.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"/>\n        </svg>\n      </div>\n      <div class=\"dt__info\">\n        <span class=\"dt__step-label\">Livraison</span>\n        <span class=\"dt__date\" id=\"dt-deliver-date\">—</span>\n        <span class=\"dt__subdate\" id=\"dt-deliver-date2\"></span>\n      </div>\n    </div>\n\n  </div>\n</div>\n<!-- ══════════════════════════════════ -->\n\n<script>\n  (function() {\n    const DAYS_FR   = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];\n    const MONTHS_FR = ['jan.','fév.','mars','avr.','mai','juin',\n                       'juil.','août','sep.','oct.','nov.','déc.'];\n\n    function isWeekend(d) { return d.getDay() === 0 || d.getDay() === 6; }\n\n    function addBusinessDays(date, n) {\n      let d = new Date(date), added = 0;\n      while (added < n) {\n        d.setDate(d.getDate() + 1);\n        if (!isWeekend(d)) added++;\n      }\n      return d;\n    }\n\n    function fmt(d) {\n      return DAYS_FR[d.getDay()] + ' ' + d.getDate() + ' ' + MONTHS_FR[d.getMonth()];\n    }\n\n    const today       = new Date();\n    const shipDate    = addBusinessDays(today, 1);\n    const deliverFrom = addBusinessDays(today, 5);\n    const deliverTo   = addBusinessDays(today, 6);\n\n    document.getElementById('dt-order-date').textContent    = fmt(today);\n    document.getElementById('dt-ship-date').textContent     = fmt(shipDate);\n    document.getElementById('dt-deliver-date').textContent  = fmt(deliverFrom);\n    document.getElementById('dt-deliver-date2').textContent = '— ' + fmt(deliverTo);\n  })();\n</script>"
