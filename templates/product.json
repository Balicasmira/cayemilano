            "liquid": "<!-- ══════════════════════════════════\n     SIZE GUIDE BUTTON + POPUP\n     Paste this where you want the button to appear\n     (near the size selector)\n══════════════════════════════════ -->\n\n<style>\n  .sg__btn {\n    display: inline-flex;\n    align-items: center;\n    gap: 6px;\n    font-size: 16px;\n    font-weight: 600;\n    color: green;\n    background: none;\n    border: none;\n    border-bottom: 1px solid #1A1A1A;\n    padding: 0 0 2px 0;\n    cursor: pointer;\n    font-family: inherit;\n    transition: opacity 0.2s;\n  }\n\n  .sg__btn:hover { opacity: 0.6; }\n\n  /* Overlay */\n  .sg__overlay {\n    display: none;\n    position: fixed;\n    inset: 0;\n    background: rgba(0,0,0,0.5);\n    z-index: 99998;\n    justify-content: center;\n    align-items: center;\n    padding: 20px;\n  }\n\n  .sg__overlay.sg--open {\n    display: flex;\n  }\n\n  /* Popup box */\n  .sg__modal {\n    background: #fff;\n    border-radius: 16px;\n    padding: 32px 28px 28px;\n    width: 100%;\n    max-width: 520px;\n    max-height: 90vh;\n    overflow-y: auto;\n    position: relative;\n    box-shadow: 0 20px 60px rgba(0,0,0,0.2);\n    animation: sgSlideIn 0.25s ease;\n  }\n\n  @keyframes sgSlideIn {\n    from { opacity: 0; transform: translateY(16px); }\n    to   { opacity: 1; transform: translateY(0); }\n  }\n\n  /* Close button */\n  .sg__close {\n    position: absolute;\n    top: 16px;\n    right: 16px;\n    width: 32px;\n    height: 32px;\n    border-radius: 50%;\n    border: 1px solid #E8E8E8;\n    background: #F8F8F8;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    cursor: pointer;\n    font-size: 16px;\n    color: #666;\n    line-height: 1;\n    transition: background 0.2s;\n  }\n\n  .sg__close:hover { background: #EBEBEB; }\n\n  /* Modal title */\n  .sg__title {\n    font-size: 17px;\n    font-weight: 700;\n    color: #1A1A1A;\n    margin-bottom: 6px;\n    padding-right: 40px;\n  }\n\n  .sg__subtitle {\n    font-size: 12px;\n    color: #888;\n    margin-bottom: 20px;\n    display: block;\n  }\n\n  /* Table */\n  .sg__table {\n    width: 100%;\n    border-collapse: collapse;\n    font-size: 13px;\n  }\n\n  .sg__table th {\n    background: #1E5A3C;\n    color: #fff;\n    padding: 10px 12px;\n    font-weight: 600;\n    text-align: center;\n    font-size: 12px;\n    letter-spacing: 0.3px;\n  }\n\n  .sg__table th:first-child { border-radius: 8px 0 0 0; }\n  .sg__table th:last-child  { border-radius: 0 8px 0 0; }\n\n  .sg__table td {\n    padding: 10px 12px;\n    text-align: center;\n    color: #1A1A1A;\n    border-bottom: 1px solid #F0F0F0;\n  }\n\n  .sg__table tr:nth-child(even) td { background: #F8F8F8; }\n  .sg__table tr:hover td { background: #F0F7F4; }\n\n  .sg__table td:first-child {\n    font-weight: 700;\n    color: #1E5A3C;\n  }\n\n  /* Tip */\n  .sg__tip {\n    margin-top: 16px;\n    padding: 12px 14px;\n    background: #F0F7F4;\n    border-radius: 10px;\n    font-size: 12px;\n    color: #1E5A3C;\n    line-height: 1.5;\n  }\n\n  /* Mobile */\n  @media (max-width: 480px) {\n    .sg__modal { padding: 24px 16px 20px; }\n    .sg__table th, .sg__table td { padding: 8px 8px; font-size: 12px; }\n  }\n</style>\n\n<!-- BUTTON -->\n<button id=\"size\" class=\"sg__btn\" onclick=\"sgOpen()\">\n  <svg width=\"14\" height=\"14\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\">\n    <path d=\"M21 10H3M16 2v8M8 2v8M3 6h18v14a2 2 0 01-2 2H5a2 2 0 01-2-2V6z\"/>\n  </svg>\n  Guide des tailles\n</button>\n\n<!-- POPUP OVERLAY -->\n<div class=\"sg__overlay\" id=\"sg-overlay\" onclick=\"sgClickOutside(event)\">\n  <div class=\"sg__modal\">\n\n    <button class=\"sg__close\" onclick=\"sgClose()\">✕</button>\n\n    <div class=\"sg__title\">📏 Guide des tailles</div>\n    <span class=\"sg__subtitle\">Toutes les mesures sont en centimètres (cm)</span>\n\n    <table class=\"sg__table\">\n      <thead>\n        <tr>\n          <th>Taille</th>\n          <th>Poitrine</th>\n          <th>Épaule</th>\n          <th>Manche</th>\n          <th>Longueur</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td>XS</td>\n          <td>—</td>\n          <td>—</td>\n          <td>—</td>\n          <td>—</td>\n        </tr>\n        <tr>\n          <td>S</td>\n          <td>96 – 100</td>\n          <td>43</td>\n          <td>62</td>\n          <td>68</td>\n        </tr>\n        <tr>\n          <td>M</td>\n          <td>100 – 104</td>\n          <td>44.5</td>\n          <td>63.5</td>\n          <td>70</td>\n        </tr>\n        <tr>\n          <td>L</td>\n          <td>104 – 108</td>\n          <td>46</td>\n          <td>65</td>\n          <td>72</td>\n        </tr>\n        <tr>\n          <td>XL</td>\n          <td>108 – 114</td>\n          <td>47.5</td>\n          <td>66.5</td>\n          <td>74</td>\n        </tr>\n        <tr>\n          <td>2XL</td>\n          <td>114 – 120</td>\n          <td>49</td>\n          <td>68</td>\n          <td>76</td>\n        </tr>\n      </tbody>\n    </table>\n\n    <div class=\"sg__tip\">\n      💡 <strong>Conseil :</strong> Prenez votre taille habituelle. Pour un effet légèrement oversize, optez pour une taille au-dessus.\n    </div>\n\n  </div>\n</div>\n\n<script>\n  function sgOpen() {\n    document.getElementById('sg-overlay').classList.add('sg--open');\n    document.body.style.overflow = 'hidden';\n  }\n\n  function sgClose() {\n    document.getElementById('sg-overlay').classList.remove('sg--open');\n    document.body.style.overflow = '';\n  }\n\n  function sgClickOutside(e) {\n    if (e.target === document.getElementById('sg-overlay')) sgClose();\n  }\n\n  // Close on ESC key\n  document.addEventListener('keydown', function(e) {\n    if (e.key === 'Escape') sgClose();\n  });\n</script>\n\n<!-- ══════════════════════════════════ -->"
