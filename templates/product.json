          "type": "liquid",
          "disabled": true,
          "settings": {
            "liquid": "<div class=\"product-info__liquid\">\n  <style>\n    .custom-shipping-container {\n      display: flex;\n      padding: 12px 16px; /* Increased padding for a taller container */\n      justify-content: space-between;\n      align-items: center;\n      align-self: stretch;\n      background-color: #f6f6f6;\n      border-radius: 10px;\n      height: 60px; /* Set fixed height for the container */\n    }\n\n    .custom-shipping-item {\n      display: flex;\n      align-items: center;\n      gap: 6px;\n    }\n\n    .text-block-shipping {\n      font-size: 10px;\n      color: #000;\n    }\n\n    .shipping-date {\n      font-weight: bold;\n    }\n\n    .free-shipping {\n      font-weight: bold;\n    }\n\n    .green-circle {\n      animation: fade 1s ease-in-out infinite;\n    }\n\n    @keyframes fade {\n      0%, 100% { opacity: 1; }\n      50% { opacity: 0.5; }\n    }\n  </style>\n\n  <script>\n    document.addEventListener(\"DOMContentLoaded\", function() {\n      var daysAfterToday = 0.5; // Set this to the number of days after today that the item will ship to the customer\n      var today = new Date();\n      var shipDate = new Date(today.setDate(today.getDate() + daysAfterToday));\n      var options = { weekday: 'short', month: 'long', day: 'numeric' };\n      var formattedDate = shipDate.toLocaleDateString('fr-FR', options);\n      document.getElementById('shipping-date').textContent = formattedDate;\n    });\n  </script>\n\n  <div class=\"custom-shipping-container\">\n    <div class=\"custom-shipping-item\">\n      <svg class=\"green-circle\" xmlns=\"http://www.w3.org/2000/svg\" width=\"12\" height=\"13\" viewBox=\"0 0 12 13\" fill=\"none\">\n        <circle cx=\"6\" cy=\"6.5\" r=\"6\" fill=\"#137333\"></circle>\n      </svg>\n      <div class=\"text-block-shipping\">Expédié le <span id=\"shipping-date\" class=\"shipping-date\">mer. 26 février</span></div>\n    </div>\n    <div class=\"custom-shipping-item\">\n      <!-- Franse vlag afbeelding -->\n      <img src=\"https://upload.wikimedia.org/wikipedia/commons/c/c3/Flag_of_France.svg\" loading=\"lazy\" alt=\"French flag\" class=\"custom-icon\" width=\"20\" height=\"15\">\n      <div class=\"text-block-shipping\"><span class=\"free-shipping\">Livraison GRATUITE</span> via LaPoste</div>\n    </div>\n  </div>\n</div>"
