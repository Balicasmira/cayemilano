<!-- LIGHTBOX — hors section pour éviter conflits z-index Shopify -->
<div class="rr__lightbox" id="rr-lightbox" onclick="rrLightboxClickOutside(event)">
  <button type="button" class="rr__lightbox-close" onclick="event.preventDefault(); event.stopPropagation(); rrLightboxClose();" aria-label="Fermer">✕</button>
  <div class="rr__lightbox-inner">
    <img class="rr__lightbox-img" id="rr-lightbox-img" src="" alt="Avis client photo">
  </div>
</div>

<script>
  function rrLoadMore(btn) {
    const hidden = document.querySelectorAll('.rr__card.rr__hidden');
    if (hidden.length === 0) { btn.style.display = 'none'; return; }
    let shown = 0;
    hidden.forEach(card => {
      if (shown < 6) { card.classList.remove('rr__hidden'); shown++; }
    });
    if (document.querySelectorAll('.rr__card.rr__hidden').length === 0) {
      btn.style.display = 'none';
    }
  }

  function rrLightboxOpen(src) {
    var lb = document.getElementById('rr-lightbox');
    if (lb.parentNode !== document.body) {
      document.body.appendChild(lb);
    }
    var img = document.getElementById('rr-lightbox-img');
    img.src = '';
    img.src = src;
    lb.classList.add('rr--open');
    document.body.style.top = '-' + window.scrollY + 'px';
    document.body.style.overflow = 'hidden';
    document.body.style.position = 'fixed';
    document.body.style.width = '100%';
  }

  function rrLightboxClose() {
    document.getElementById('rr-lightbox').classList.remove('rr--open');
    var scrollY = document.body.style.top;
    document.body.style.overflow = '';
    document.body.style.position = '';
    document.body.style.width = '';
    document.body.style.top = '';
    if (scrollY) {
      window.scrollTo(0, parseInt(scrollY || '0') * -1);
    }
  }

  function rrLightboxClickOutside(e) {
    var lb = document.getElementById('rr-lightbox');
    var inner = lb.querySelector('.rr__lightbox-inner');
    if (!inner.contains(e.target) || e.target === lb) rrLightboxClose();
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') rrLightboxClose();
  });
</script>
