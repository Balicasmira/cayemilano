<script>
  function rrLoadMore(btn) {
    const hidden = document.querySelectorAll('.rr__card.rr__hidden');
    if (hidden.length === 0) { btn.style.display = 'none'; return; }
    let shown = 0;
    hidden.forEach(card => {
      if (shown < 6) { card.classList.remove('rr__hidden'); shown++; }
    });
    if (document.querySelectorAll('.rr__card.rr__hidden').length === 0) {
      btn.style.display = 'none';
    }
  }

  function rrLightboxOpen(src) {
    document.getElementById('rr-lightbox-img').src = src;
    document.getElementById('rr-lightbox').classList.add('rr--open');
    document.body.style.overflow = 'hidden';
  }

  function rrLightboxClose() {
    document.getElementById('rr-lightbox').classList.remove('rr--open');
    document.body.style.overflow = '';
  }

  function rrLightboxClickOutside(e) {
    if (e.target === document.getElementById('rr-lightbox')) rrLightboxClose();
  }

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') rrLightboxClose();
  });
</script>
