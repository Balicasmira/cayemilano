{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
VARIANT ADDED — with upsell + Quick View popup
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<style>
  .kiel-upsell {
    margin: 12px 0 4px;
    border: 1.5px solid #E8D9C0;
    border-radius: 12px;
    overflow: hidden;
    background: #FAFAF7;
  }
  .kiel-upsell__label {
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    color: #8B7355;
    padding: 10px 14px 6px;
    display: block;
  }
  .kiel-upsell__row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 0 14px 14px;
  }
  .kiel-upsell__img {
    width: 64px;
    height: 64px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
    cursor: pointer;
    transition: opacity 0.2s;
  }
  .kiel-upsell__img:hover { opacity: 0.85; }
  .kiel-upsell__info { flex: 1; min-width: 0; }
  .kiel-upsell__name {
    font-size: 13px;
    font-weight: 700;
    color: #1A1610;
    display: block;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .kiel-upsell__price {
    font-size: 12px;
    color: #8B7355;
    display: block;
    margin-top: 2px;
  }
  .kiel-upsell__btn {
    margin-top: 8px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 7px 14px;
    background: #1A1610;
    color: #F5F0E8;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    border: none;
    border-radius: 20px;
    cursor: pointer;
    transition: background 0.2s;
    font-family: inherit;
  }
  .kiel-upsell__btn:hover { background: #333; }

  /* QUICK VIEW OVERLAY */
  .kiel-qv-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 999999;
    justify-content: center;
    align-items: center;
    padding: 20px;
  }
  .kiel-qv-overlay.kiel-qv--open { display: flex; }
  .kiel-qv-modal {
    background: #fff;
    border-radius: 16px;
    width: 100%;
    max-width: 420px;
    padding: 24px;
    position: relative;
    animation: kielQvIn 0.2s ease;
    max-height: 90vh;
    overflow-y: auto;
  }
  @keyframes kielQvIn {
    from { opacity: 0; transform: scale(0.96) translateY(10px); }
    to   { opacity: 1; transform: scale(1) translateY(0); }
  }
  .kiel-qv-close {
    position: absolute;
    top: 12px;
    right: 14px;
    background: none;
    border: none;
    font-size: 20px;
    color: #999;
    cursor: pointer;
    line-height: 1;
    padding: 0;
  }
  .kiel-qv-close:hover { color: #1A1610; }
  .kiel-qv__img {
    width: 100%;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 10px;
    margin-bottom: 16px;
  }
  .kiel-qv__name {
    font-size: 16px;
    font-weight: 700;
    color: #1A1610;
    margin: 0 0 8px;
    font-family: 'Playfair Display', Georgia, serif;
  }
  .kiel-qv__price-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 16px;
  }
  .kiel-qv__price-sale { font-size: 18px; font-weight: 700; color: #1A1610; }
  .kiel-qv__price-orig { font-size: 14px; color: #B0A08A; text-decoration: line-through; }
  .kiel-qv__badge { font-size: 11px; font-weight: 700; background: #1A1610; color: #F5F0E8; padding: 2px 8px; border-radius: 20px; }
  .kiel-qv__size-label {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: #8B7355;
    display: block;
    margin-bottom: 8px;
  }
  .kiel-qv__sizes { display: flex; gap: 8px; flex-wrap: wrap; margin-bottom: 18px; }
  .kiel-qv__size-btn {
    width: 44px;
    height: 44px;
    border: 1.5px solid #D4C4A0;
    border-radius: 8px;
    background: #fff;
    font-size: 12px;
    font-weight: 600;
    color: #1A1610;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }
  .kiel-qv__size-btn:hover,
  .kiel-qv__size-btn.kiel-qv--selected {
    background: #1A1610;
    color: #fff;
    border-color: #1A1610;
  }
  .kiel-qv__atc {
    width: 100%;
    padding: 14px;
    background: #1A1610;
    color: #F5F0E8;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    border: none;
    border-radius: 30px;
    cursor: pointer;
    font-family: inherit;
    transition: background 0.2s;
  }
  .kiel-qv__atc:hover { background: #333; }
  .kiel-qv__atc:disabled { background: #C4B49A; cursor: not-allowed; }
  .kiel-qv__msg {
    font-size: 12px;
    text-align: center;
    margin-top: 10px;
    color: #2D6A4F;
    font-weight: 600;
    display: none;
  }
</style>

<div class="quick-buy-drawer__info">

  {%- for line_item in cart.items -%}
    <div class="quick-buy-drawer__variant text-start h-stack gap-6">
      {%- assign image = line_item.variant.featured_media | default: line_item.product.featured_media -%}
      {%- if image != blank -%}
        {{- image | image_url: width: image.width | image_tag: loading: 'lazy', sizes: '80px', widths: '80,160', class: 'quick-buy-drawer__media rounded-xs' -}}
      {%- endif -%}
      <div class="v-stack gap-1">
        <div class="v-stack gap-0.5">
          <a href="{{ line_item.variant.url }}" class="bold justify-self-start">{{ line_item.product.title }}</a>
          {%- render 'price-list', product: line_item.product, line_item: line_item -%}
        </div>
        {%- if line_item.line_level_discount_allocations != blank -%}
          <ul class="contents" role="list">
            {%- for discount_allocation in line_item.line_level_discount_allocations -%}
              <li class="badge">
                {%- render 'icon' with 'discount' -%} {{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}
        {%- unless line_item.product.has_only_default_variant -%}
          <p class="text-sm text-subdued">{{ line_item.variant.title }}</p>
        {%- endunless -%}
      </div>
    </div>
  {%- endfor -%}

  {%- comment -%} Show upsell only if cardigan is in cart {%- endcomment -%}
  {%- assign kiel_show_upsell = false -%}
  {%- for line_item in cart.items -%}
    {%- if line_item.product.handle == 'lacoste-cardigan-signature-pour-homme' -%}
      {%- assign kiel_show_upsell = true -%}
    {%- endif -%}
  {%- endfor -%}

  {%- if kiel_show_upsell -%}
  <div class="kiel-upsell">
    <span class="kiel-upsell__label">Complétez votre look</span>
    <div class="kiel-upsell__row">
      <img
        class="kiel-upsell__img"
        src="https://kielamsterdam.com/cdn/shop/files/dzdzdzdzdz.png?v=1761758025&width=300"
        alt="Pull L'Heritage"
        onclick="kielQvOpen()"
      >
      <div class="kiel-upsell__info">
        <span class="kiel-upsell__name">Pull L'Heritage</span>
        <span class="kiel-upsell__price">€44,99 &nbsp;<s style="color:#B0A08A;font-size:11px;">€110,00</s></span>
        <br>
        <button class="kiel-upsell__btn" onclick="kielQvOpen()">Compléter ma commande</button>
      </div>
    </div>
  </div>
  {%- endif -%}

  <form action="{{ routes.cart_url }}" style="padding:10px;" method="post" class="buy-buttons buy-buttons--compact">
    {%- assign checkout_label = 'cart.general.checkout' | t -%}
    {%- render 'button', type: 'submit', name: 'checkout', content: checkout_label -%}
  </form>

  <div class="v-stack gap-4">
    <span class="text-xs text-subdued text-center">🔒 Paiement sécurisé avec:</span>
    <div class="h-stack gap-2 wrap justify-center">
      <svg xmlns="http://www.w3.org/2000/svg" role="img" viewBox="0 0 38 24" width="38" height="24"><path fill="#000" d="M35 0H3C1.3 0 0 1.3 0 3v18c0 1.7 1.4 3 3 3h32c1.7 0 3-1.3 3-3V3c0-1.7-1.4-3-3-3Z" opacity=".07"/><path fill="#006FCF" d="M35 1c1.1 0 2 .9 2 2v18c0 1.1-.9 2-2 2H3c-1.1 0-2-.9-2-2V3c0-1.1.9-2 2-2h32Z"/><path fill="#FFF" d="M22.012 19.936v-8.421L37 11.528v2.326l-1.732 1.852L37 17.573v2.375h-2.766l-1.47-1.622-1.46 1.628-9.292-.02Z"/><path fill="#006FCF" d="M23.013 19.012v-6.57h5.572v1.513h-3.768v1.028h3.678v1.488h-3.678v1.01h3.768v1.531h-5.572Z"/><path fill="#006FCF" d="m28.557 19.012 3.083-3.289-3.083-3.282h2.386l1.884 2.083 1.89-2.082H37v.051l-3.017 3.23L37 18.92v.093h-2.307l-1.917-2.103-1.898 2.104h-2.321Z"/><path fill="#FFF" d="M22.71 4.04h3.614l1.269 2.881V4.04h4.46l.77 2.159.771-2.159H37v8.421H19l3.71-8.421Z"/><path fill="#006FCF" d="m23.395 4.955-2.916 6.566h2l.55-1.315h2.98l.55 1.315h2.05l-2.904-6.566h-2.31Zm.25 3.777.875-2.09.873 2.09h-1.748Z"/><path fill="#006FCF" d="M28.581 11.52V4.953l2.811.01L32.84 9l1.456-4.046H37v6.565l-1.74.016v-4.51l-1.644 4.494h-1.59L30.35 7.01v4.51h-1.768Z"/></svg>
      <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24"><path opacity=".07" d="M35 0H3C1.3 0 0 1.3 0 3v18c0 1.7 1.4 3 3 3h32c1.7 0 3-1.3 3-3V3c0-1.7-1.4-3-3-3z"/><path fill="#fff" d="M35 1c1.1 0 2 .9 2 2v18c0 1.1-.9 2-2 2H3c-1.1 0-2-.9-2-2V3c0-1.1.9-2 2-2h32"/><circle fill="#EB001B" cx="15" cy="12" r="7"/><circle fill="#F79E1B" cx="23" cy="12" r="7"/><path fill="#FF5F00" d="M22 12c0-2.4-1.2-4.5-3-5.7-1.8 1.3-3 3.4-3 5.7s1.2 4.5 3 5.7c1.8-1.2 3-3.3 3-5.7z"/></svg>
      <svg viewBox="0 0 38 24" xmlns="http://www.w3.org/2000/svg" role="img" width="38" height="24"><path opacity=".07" d="M35 0H3C1.3 0 0 1.3 0 3v18c0 1.7 1.4 3 3 3h32c1.7 0 3-1.3 3-3V3c0-1.7-1.4-3-3-3z"/><path fill="#fff" d="M35 1c1.1 0 2 .9 2 2v18c0 1.1-.9 2-2 2H3c-1.1 0-2-.9-2-2V3c0-1.1.9-2 2-2h32"/><path d="M28.3 10.1H28c-.4 1-.7 1.5-1 3h1.9c-.3-1.5-.3-2.2-.6-3zm2.9 5.9h-1.7c-.1 0-.1 0-.2-.1l-.2-.9-.1-.2h-2.4c-.1 0-.2 0-.2.2l-.3.9c0 .1-.1.1-.1.1h-2.1l.2-.5L27 8.7c0-.5.3-.7.8-.7h1.5c.1 0 .2 0 .2.2l1.4 6.5c.1.4.2.7.2 1.1.1.1.1.1.1.2zm-13.4-.3l.4-1.8c.1 0 .2.1.2.1.7.3 1.4.5 2.1.4.2 0 .5-.1.7-.2.5-.2.5-.7.1-1.1-.2-.2-.5-.3-.8-.5-.4-.2-.8-.4-1.1-.7-1.2-1-.8-2.4-.1-3.1.6-.4.9-.8 1.7-.8 1.2 0 2.5 0 3.1.2h.1c-.1.6-.2 1.1-.4 1.7-.5-.2-1-.4-1.5-.4-.3 0-.6 0-.9.1-.2 0-.3.1-.4.2-.2.2-.2.5 0 .7l.5.4c.4.2.8.4 1.1.6.5.3 1 .8 1.1 1.4.2.9-.1 1.7-.9 2.3-.5.4-.7.6-1.4.6-1.4 0-2.5.1-3.4-.2-.1.2-.1.2-.2.1zm-3.5.3c.1-.7.1-.7.2-1 .5-2.2 1-4.5 1.4-6.7.1-.2.1-.3.3-.3H18c-.2 1.2-.4 2.1-.7 3.2-.3 1.5-.6 3-1 4.5 0 .2-.1.2-.3.2M5 8.2c0-.1.2-.2.3-.2h3.4c.5 0 .9.3 1 .8l.9 4.4c0 .1 0 .1.1.2 0-.1.1-.1.1-.1l2.1-5.1c-.1-.1 0-.2.1-.2h2.1c0 .1 0 .1-.1.2l-3.1 7.3c-.1.2-.1.3-.2.4-.1.1-.3 0-.5 0H9.7c-.1 0-.2 0-.2-.2L7.9 9.5c-.2-.2-.5-.5-.9-.6-.6-.3-1.7-.5-1.9-.5L5 8.2z" fill="#142688"/></svg>
    </div>
  </div>

</div>


<script>
  function kielQvOpen() {
    var existing = document.getElementById("kiel-qv-overlay");
    if (existing) existing.remove();
    var html = '<div id="kiel-qv-overlay" style="display:flex;position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:2147483647;justify-content:center;align-items:center;padding:20px;" onclick="if(event.target.id===\x27kiel-qv-overlay\x27)kielQvClose()"><div style="background:#fff;border-radius:16px;width:100%;max-width:420px;padding:24px;position:relative;max-height:90vh;overflow-y:auto;"><button onclick="kielQvClose()" style="position:absolute;top:12px;right:14px;background:none;border:none;font-size:22px;color:#999;cursor:pointer;">✕</button><img src="https://kielamsterdam.com/cdn/shop/files/dzdzdzdzdz.png?v=1761758025\x26width=800" style="width:100%;aspect-ratio:1/1;object-fit:cover;border-radius:10px;margin-bottom:16px;"><h3 style="font-size:16px;font-weight:700;color:#1A1610;margin:0 0 8px;font-family:Georgia,serif;">Pull L\x27Heritage</h3><div style="display:flex;align-items:center;gap:10px;margin-bottom:16px;"><span style="font-size:18px;font-weight:700;">€44,99</span><span style="font-size:14px;color:#B0A08A;text-decoration:line-through;">€110,00</span><span style="font-size:11px;font-weight:700;background:#1A1610;color:#fff;padding:2px 8px;border-radius:20px;">-59%</span></div><p style="font-size:11px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:#8B7355;margin:0 0 8px;">CHOISIR UNE TAILLE</p><div style="display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px;"><button onclick="kielSz(this)" data-v="52080247013704" style="width:44px;height:44px;border:1.5px solid #D4C4A0;border-radius:8px;background:#fff;font-size:12px;font-weight:600;cursor:pointer;">S</button><button onclick="kielSz(this)" data-v="52080247013704" style="width:44px;height:44px;border:1.5px solid #D4C4A0;border-radius:8px;background:#fff;font-size:12px;font-weight:600;cursor:pointer;">M</button><button onclick="kielSz(this)" data-v="52080247013704" style="width:44px;height:44px;border:1.5px solid #D4C4A0;border-radius:8px;background:#fff;font-size:12px;font-weight:600;cursor:pointer;">L</button><button onclick="kielSz(this)" data-v="52080247013704" style="width:44px;height:44px;border:1.5px solid #D4C4A0;border-radius:8px;background:#fff;font-size:12px;font-weight:600;cursor:pointer;">XL</button><button onclick="kielSz(this)" data-v="52080247013704" style="width:44px;height:44px;border:1.5px solid #D4C4A0;border-radius:8px;background:#fff;font-size:12px;font-weight:600;cursor:pointer;">2XL</button></div><button id="kqatc" onclick="kielQvAtc()" disabled style="width:100%;padding:14px;background:#C4B49A;color:#fff;font-size:13px;font-weight:700;letter-spacing:2px;text-transform:uppercase;border:none;border-radius:30px;cursor:not-allowed;">Sélectionner une taille</button><p id="kqmsg" style="font-size:12px;text-align:center;margin-top:10px;color:#2D6A4F;font-weight:600;display:none;">✓ Ajouté au panier !</p></div></div>';
    document.body.insertAdjacentHTML("beforeend", html);
    document.body.style.overflow = "hidden";
  }
  function kielQvClose() {
    var o = document.getElementById("kiel-qv-overlay");
    if (o) o.remove();
    document.body.style.overflow = "";
  }
  function kielSz(btn) {
    document.querySelectorAll("[data-v]").forEach(function(b) { b.style.background="#fff"; b.style.color="#1A1610"; b.style.borderColor="#D4C4A0"; });
    btn.style.background="#1A1610"; btn.style.color="#fff"; btn.style.borderColor="#1A1610";
    btn._selected = true;
    var atc = document.getElementById("kqatc");
    atc.disabled = false;
    atc.style.background = "#1A1610";
    atc.style.cursor = "pointer";
    atc.textContent = "Ajouter au panier";
    atc._variant = btn.getAttribute("data-v");
  }
  function kielQvAtc() {
    var atc = document.getElementById("kqatc");
    var msg = document.getElementById("kqmsg");
    if (!atc._variant) return;
    atc.disabled = true;
    atc.textContent = "Ajout en cours...";
    fetch("/cart/add.js", { method:"POST", headers:{"Content-Type":"application/json"}, body:JSON.stringify({id:atc._variant, quantity:1}) })
    .then(function(r){return r.json();})
    .then(function(){ atc.textContent="✓ Ajouté !"; msg.style.display="block"; setTimeout(kielQvClose, 1400); })
    .catch(function(){ atc.disabled=false; atc.textContent="Ajouter au panier"; });
  }
  document.addEventListener("keydown", function(e){ if(e.key==="Escape") kielQvClose(); });
</script>

{% schema %}
{
  "name": "Variant added"
}
{% endschema %}
