{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
VARIANT ADDED
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<div class="quick-buy-drawer__info">
<style>
  .kiel-stars-bar {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    cursor: pointer;
    text-decoration: none;
  }

  .kiel-stars-bar__stars {
    display: flex;
    align-items: center;
    gap: 1px;
  }

  .kiel-stars-bar__stars svg {
    display: block;
  }

  .kiel-stars-bar__label {
    font-family: 'Jost', 'DM Sans', Arial, sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: green;
    border-bottom: 1px solid #C4B49A;
    padding-bottom: 1px;
    transition: color 0.2s, border-color 0.2s;
  }

  .kiel-stars-bar:hover .kiel-stars-bar__label {
    color: green;
    border-color: green;
  }
</style>

<div class="kiel-stars-bar" onclick="kielScrollToReviews()">

  <div class="kiel-stars-bar__stars">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="green"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="green"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="green"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="green"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>
    <svg width="14" height="14" viewBox="0 0 24 24">
      <defs>
        <linearGradient id="kiel-half-grad">
          <stop offset="50%" stop-color="green"/>
          <stop offset="50%" stop-color="grey"/>
        </linearGradient>
      </defs>
      <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" fill="url(#kiel-half-grad)"/>
    </svg>
  </div>

  <span class="kiel-stars-bar__label">4,8/5 · Avis clients vérifiés</span>

</div>


</div>

   {%- if section.blocks[next_block_index].type == 'offer' -%}
                      <div class="v-stack gap-4">
                    {%- endif -%}

                    {%- render 'offer', block: block -%}

                    {%- if section.blocks[previous_block_index].type == 'offer' -%}
                      </div>
                    {%- endif -%}
  {%- for line_item in cart.items -%}
    <div class="quick-buy-drawer__variant text-start h-stack gap-6">
      {%- assign image = line_item.variant.featured_media | default: line_item.product.featured_media -%}

      {%- if image != blank -%}
        {{- image | image_url: width: image.width | image_tag: loading: 'lazy', sizes: '80px', widths: '80,160', class: 'quick-buy-drawer__media rounded-xs' -}}
      {%- endif -%}

      <div class="v-stack gap-1">
        <div class="v-stack gap-0.5">
          <a href="{{ line_item.variant.url }}" class="bold justify-self-start">{{ line_item.product.title }}</a>
          {%- render 'price-list', product: line_item.product, line_item: line_item -%}
        </div>

        {%- if line_item.line_level_discount_allocations != blank -%}
          <ul class="contents" role="list">
            {%- for discount_allocation in line_item.line_level_discount_allocations -%}
              <li class="badge">
                {%- render 'icon' with 'discount' -%} {{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- unless line_item.product.has_only_default_variant -%}
          <p class="text-sm text-subdued">{{ line_item.variant.title }}</p>
        {%- endunless -%}
      </div>
    </div>
  {%- endfor -%}

  <form action="{{ routes.cart_url }}"  method="post" class="buy-buttons buy-buttons--compact">
    
    {%- assign checkout_label = 'cart.general.checkout' | t -%}

    {%- render 'button', type: 'submit', name: 'checkout', content: checkout_label -%}
  </form>
</div>

{% schema %}
{
  "name": "Variant added"
}
{% endschema %}
