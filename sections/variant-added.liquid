{%- comment -%}
----------------------------------------------------------------------------------------------------------------------
VARIANT ADDED
----------------------------------------------------------------------------------------------------------------------
{%- endcomment -%}

<div class="quick-buy-drawer__info">
<div class="shipping-container">

<style>
.shipping-container {
  text-align: center;
}

.delivery-box {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 6px 10px;
  font-family: 'Jost', 'DM Sans', Arial, sans-serif;

  border: 1.5px solid #1A1610;
  border-radius: 8px;
  background-color: #ffffff;
}

.delivery-icon {
  color: #1A1610;
  display: flex;
  align-items: center;
  flex-shrink: 0;
}

.delivery-icon svg {
  width: 20px;
  height: 20px;
}

.delivery-date {
  font-size: 13px;
  font-weight: 500;
  color: #1A1610;
}

.delivery-space {
  display: inline-block;
  width: 6px;
}

.delivery-free {
  font-size: 13px;
  font-weight: 700;
  color: #16A34A;
}
</style>

<div class="delivery-box">
  <div class="delivery-icon">
    <svg viewBox="0 0 24 24" fill="currentColor">
      <path d="M2.231 8.25h2.282a.75.75 0 0 0 0-1.5H2.231a.75.75 0 0 0 0 1.5m2.266 3a.75.75 0 0 0 0-1.5H.753a.75.75 0 0 0 0 1.5zm.017 3.001a.75.75 0 0 0 0-1.5H2.21a.75.75 0 0 0 0 1.5z"></path>
      <path d="m23.81 11.501-3.368-3.738a.75.75 0 0 0-.557-.248h-3.378V4.497a.75.75 0 0 0-.75-.75H3.711a.75.75 0 0 0 0 1.5l11.298-.004.003 10.513-4.953.004c-.519-.897-1.478-1.508-2.588-1.508s-2.07.61-2.588 1.508H3.712a.75.75 0 1 0 0 1.5h.76a2.999 2.999 0 0 0 5.998 0h5.276l.76.003a2.999 2.999 0 0 0 5.997 0h.749a.75.75 0 0 0 .75-.75v-4.51a.75.75 0 0 0-.193-.502"></path>
    </svg>
  </div>

  <div>
    <strong>Livraison estimée:</strong><br>
    <span class="delivery-date" id="delivery-dates"></span>
    <span class="delivery-space"></span>
    <span class="delivery-free">Gratuit</span>
  </div>
</div>

<script>
(function(){
  var tz = 'Europe/Paris';
  var days = ['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];
  var months = ['Jan','Fév','Mars','Avr','Mai','Jun','Jul','Aoû','Sep','Oct','Nov','Déc'];

  function nowParis(){
    return new Date(new Date().toLocaleString('en-US', { timeZone: tz }));
  }

  function addBizDays(date, num){
    var result = new Date(date), added = 0;
    while(added < num){
      result.setDate(result.getDate() + 1);
      if(result.getDay() !== 0 && result.getDay() !== 5) added++;
    }
    return result;
  }

  function formatDate(d){
    return days[d.getDay()] + ' ' + d.getDate() + ' ' + months[d.getMonth()];
  }

  var now = nowParis();
  var base = new Date(now);
  base.setDate(base.getDate() + 1);

  while(base.getDay() === 0 || base.getDay() === 5){
    base.setDate(base.getDate() + 1);
  }

  document.getElementById('delivery-dates').textContent =
    formatDate(addBizDays(base, 3)) + ' – ' + formatDate(addBizDays(base, 5));
})();
</script>

</div>
</div>

  <div class="banner banner--success justify-center">
    <p style="color: black;"><strong>Nos partenaires de livraison:</strong></p><br>
    <ul style="display: flex; gap: 0px; list-style: none; padding: 0; margin: 0;">
      <li><img style="width: 50px; height: 47px; object-fit: contain;" src="https://mosaic01.ztat.net/zds/assets/svg/colissimo.2f4378f.svg" alt="Colissimo"></li>
      <li><img style="width: 50px; height: 47px; object-fit: contain;" src="https://mosaic01.ztat.net/zds/assets/svg/chronopost.2154cb4.svg" alt="Chronopost"></li>
      <li><img style="width: 50px; height: 47px; object-fit: contain;" src="https://upload.wikimedia.org/wikipedia/fr/0/0d/La_Poste_2022.svg" alt="Mondial Relay"></li>
    </ul>
  </div>
  {%- for line_item in cart.items -%}
    <div class="quick-buy-drawer__variant text-start h-stack gap-6">
      {%- assign image = line_item.variant.featured_media | default: line_item.product.featured_media -%}

      {%- if image != blank -%}
        {{- image | image_url: width: image.width | image_tag: loading: 'lazy', sizes: '80px', widths: '80,160', class: 'quick-buy-drawer__media rounded-xs' -}}
      {%- endif -%}

      <div class="v-stack gap-1">
        <div class="v-stack gap-0.5">
          <a href="{{ line_item.variant.url }}" class="bold justify-self-start">{{ line_item.product.title }}</a>
          {%- render 'price-list', product: line_item.product, line_item: line_item -%}
        </div>

        {%- if line_item.line_level_discount_allocations != blank -%}
          <ul class="contents" role="list">
            {%- for discount_allocation in line_item.line_level_discount_allocations -%}
              <li class="badge">
                {%- render 'icon' with 'discount' -%} {{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})
              </li>
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- unless line_item.product.has_only_default_variant -%}
          <p class="text-sm text-subdued">{{ line_item.variant.title }}</p>
        {%- endunless -%}
      </div>
    </div>
  {%- endfor -%}

  <form action="{{ routes.cart_url }}" method="post" class="buy-buttons buy-buttons--compact">
    
    {%- assign checkout_label = 'cart.general.checkout' | t -%}

    {%- render 'button', type: 'submit', name: 'checkout', content: checkout_label -%}
  </form>
</div>

{% schema %}
{
  "name": "Variant added"
}
{% endschema %}
